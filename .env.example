# StockSpot minimal environment template
# Dotenv is loaded only by backend/server.js

# =============================================================================
# REQUIRED PRODUCTION VARIABLES
# =============================================================================

# MongoDB connection string (required)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/stockspot

# JWT secret for authentication tokens (required - generate a strong random value)
JWT_SECRET=change-this-to-a-random-secret-in-production

# Stripe keys (required for subscriptions)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price ID for the premium subscription (required)
STRIPE_PRICE_ID=price_your-price-id-here

# Resend API key for email notifications (required for email delivery)
RESEND_API_KEY=

# Amazon Associate ID for affiliate link generation (optional - set for monetization)
AMAZON_ASSOCIATE_ID=

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Server port (default: 3000)
PORT=3000

# Application environment
NODE_ENV=development

# Frontend URL for CORS and redirects
FRONTEND_URL=http://localhost:3000

# Enable/disable email notifications
EMAIL_ENABLED=true
EMAIL_FROM=alerts@stockspot.com
EMAIL_FROM_NAME=StockSpot Alerts

# Dry-run mode - set to false in production for actual monitoring and email delivery
DRY_RUN=false

# =============================================================================
# OWNER BOOTSTRAP
# =============================================================================
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me
BOOTSTRAP_OWNER=0

# =============================================================================
# OBSERVER ENGINE SCHEDULING (Autonomous feed ingestion)
# =============================================================================
# Observer runs every N minutes to check for new deals and restocks
MONITOR_INTERVAL_MINUTES=5
RESTOCK_CHECK_INTERVAL_MINUTES=2
MAX_RETRIES=3
RETRY_DELAY=1000

# =============================================================================
# FEED CONFIGURATION (RSS + Email)
# =============================================================================
FEED_MAX_ITEMS=100
FEED_RETENTION_DAYS=7

# =============================================================================
# TIER SYSTEM (FREE / PAID / YEARLY)
# =============================================================================
FREE_TIER_DELAY_MINUTES=10
AFFILIATE_LINK_AUTO_CONVERT=true

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================
LOG_LEVEL=info
DEBUG=false

# =============================================================================
# RENDER.COM DEPLOYMENT (Auto-set by Render - do not modify)
# =============================================================================
# PORT and DATABASE will be automatically set by Render environment