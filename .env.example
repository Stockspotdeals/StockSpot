# StockSpot v3.0 - Environment Configuration Example
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000
DRY_RUN=true
DRY_RUN_MOCK_DATA=true

# Database
MONGO_URI=mongodb://localhost:27017/stockspot
DATABASE_TYPE=mongodb

# Amazon Affiliate
AMAZON_ASSOCIATE_TAG=stockspotde02-20
AMAZON_ASSOCIATE_ID=stockspotde02-20
AMAZON_PARTNER_TAG=stockspotde02-20
AFFILIATE_LINK_AUTO_CONVERT=true

# Email
EMAIL_ENABLED=true
EMAIL_FROM=alerts@stockspot.com
EMAIL_FROM_NAME=StockSpot Alerts

# Stripe
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_MONTHLY_ID=price_monthly_id
STRIPE_PRICE_YEARLY_ID=price_yearly_id

# Monitoring
MONITOR_INTERVAL_MINUTES=5
RESTOCK_CHECK_INTERVAL_MINUTES=2
MAX_RETRIES=3
RETRY_DELAY=1000
FEED_MAX_ITEMS=100
FEED_RETENTION_DAYS=7
FREE_TIER_DELAY_MINUTES=10

# Tier Pricing
TIER_FREE_PRICE=0
TIER_PAID_PRICE=9.99
TIER_YEARLY_PRICE=99.00

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY=7d
BCRYPT_ROUNDS=10

# Logging
LOG_LEVEL=info
DEBUG=false

# Resend
RESEND_API_KEY=